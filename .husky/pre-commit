# Skip in git worktrees — .git is a file there (not a directory).
# Agent commits in worktrees are covered by claude/hooks/pre-commit instead.
if [ -f ".git" ]; then
  exit 0
fi
bash scripts/check-conflict-markers.sh --staged
# lint-staged runs eslint on staged files, which enforces the file-length hard
# cap via the `max-lines` rule (no separate length check needed).
pnpm exec lint-staged
pnpm run env:validate
